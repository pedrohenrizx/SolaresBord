<%- include('partials/header') %>

    <!-- Sidebar -->
    <aside id="sidebar" class="absolute md:static z-30 transform -translate-x-full md:translate-x-0 transition-transform duration-300 w-64 bg-white dark:bg-gray-800 shadow-lg md:shadow-md md:flex-shrink-0 min-h-[calc(100vh-4rem)] flex flex-col justify-between">
        <div class="p-4">
            <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Menu</h2>
            <ul class="space-y-2">
                <li>
                    <a href="/dashboard" class="block px-4 py-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                        <i class="fas fa-home w-5"></i> Dashboard
                    </a>
                </li>
                <li>
                    <a href="/segmentation" class="block px-4 py-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                        <i class="fas fa-users w-5"></i> Segmentação
                    </a>
                </li>
                <li>
                    <a href="/advanced" class="block px-4 py-2 rounded-lg bg-purple-50 text-purple-600 dark:bg-purple-900/20 dark:text-purple-400 font-medium group">
                        <i class="fas fa-cogs w-5 group-hover:rotate-90 transition-transform"></i> Funcionalidades Avançadas
                    </a>
                </li>
            </ul>
        </div>

        <!-- Sidebar Collapse Hint -->
        <div class="p-4 border-t border-gray-100 dark:border-gray-700 hidden md:block text-center text-xs text-gray-400 cursor-pointer hover:text-gray-600 transition-colors">
            <i class="fas fa-angle-double-left mr-1"></i> Ocultar Menu
        </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 p-4 md:p-8 w-full overflow-x-hidden">
        <div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-center border-b border-gray-200 dark:border-gray-700 pb-4 gap-4">
            <div>
                <h1 class="text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-purple-500 to-indigo-500">Funcionalidades Avançadas</h1>
                <p class="text-gray-600 dark:text-gray-400 text-sm">Monitoramento preditivo, gamificação e mapas de calor.</p>
            </div>
            <div class="flex gap-2">
                <button class="bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-3 py-1.5 rounded-lg text-sm hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors shadow-sm" onclick="showToast('Sincronização iniciada', 'info')">
                    <i class="fas fa-sync-alt mr-1"></i> Sincronizar
                </button>
                <div class="text-3xl text-purple-500 ml-2 hidden sm:block">
                    <i class="fas fa-cogs"></i>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Predição de Churn -->
            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border-t-4 border-red-500 flex flex-col">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center">
                        <div class="p-2 bg-red-100 dark:bg-red-900/30 text-red-500 rounded-lg mr-3">
                            <i class="fas fa-exclamation-triangle"></i>
                        </div>
                        <h3 class="font-bold text-gray-800 dark:text-gray-200">Previsão de Churn</h3>
                    </div>
                    <span class="text-xs bg-red-100 text-red-800 dark:bg-red-900/50 dark:text-red-300 px-2 py-1 rounded-full font-medium">Crítico</span>
                </div>
                <p class="text-gray-600 dark:text-gray-400 mb-4 text-sm">O sistema identificou 3 clientes com alto risco de cancelamento baseados no comportamento recente.</p>
                <div class="space-y-3">
                    <div class="flex justify-between items-center bg-gray-50 dark:bg-gray-700/50 p-2 rounded">
                        <span class="font-medium text-sm">Empresa Beta</span>
                        <span class="text-xs bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300 px-2 py-1 rounded">Risco: 89%</span>
                    </div>
                    <div class="flex justify-between items-center bg-gray-50 dark:bg-gray-700/50 p-2 rounded">
                        <span class="font-medium text-sm">Carlos Almeida</span>
                        <span class="text-xs bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300 px-2 py-1 rounded">Risco: 75%</span>
                    </div>
                </div>
                <button class="mt-4 w-full text-center text-sm text-primary hover:underline">Ver relatório completo</button>
            </div>

            <!-- Heatmap Mockup -->
            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border-t-4 border-purple-500 flex flex-col lg:col-span-2">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center">
                        <div class="p-2 bg-purple-100 dark:bg-purple-900/30 text-purple-500 rounded-lg mr-3">
                            <i class="fas fa-map text-xl"></i>
                        </div>
                        <h3 class="font-bold text-gray-800 dark:text-gray-200">Heatmap de Navegação</h3>
                    </div>
                    <select class="text-xs border-gray-300 dark:border-gray-600 dark:bg-gray-700 rounded p-1">
                        <option>Página de Checkout</option>
                        <option>Página Inicial</option>
                    </select>
                </div>
                <div class="flex-1 bg-gray-100 dark:bg-gray-900 rounded-lg relative overflow-hidden flex items-center justify-center border border-gray-200 dark:border-gray-700 min-h-[200px]">
                    <!-- Mocked Heatmap -->
                    <div class="absolute top-[20%] left-[30%] w-32 h-32 bg-red-500/40 blur-xl rounded-full"></div>
                    <div class="absolute top-[50%] left-[60%] w-24 h-24 bg-yellow-500/40 blur-lg rounded-full"></div>
                    <div class="absolute top-[70%] left-[20%] w-40 h-40 bg-blue-500/30 blur-xl rounded-full"></div>

                    <div class="relative z-10 opacity-50 pointer-events-none w-full max-w-sm">
                        <div class="h-8 bg-gray-300 dark:bg-gray-700 rounded mb-4 w-3/4 mx-auto"></div>
                        <div class="h-32 bg-gray-300 dark:bg-gray-700 rounded mb-4 w-full"></div>
                        <div class="h-10 bg-gray-300 dark:bg-gray-700 rounded w-1/2 mx-auto"></div>
                    </div>
                    <div class="absolute bottom-2 right-2 flex items-center gap-1 text-[10px] bg-white/80 dark:bg-gray-800/80 px-2 py-1 rounded">
                        <span>Frio</span>
                        <div class="w-16 h-2 bg-gradient-to-r from-blue-500 via-yellow-500 to-red-500 rounded-full"></div>
                        <span>Quente</span>
                    </div>
                </div>
            </div>

            <!-- Gamificação -->
            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border-t-4 border-yellow-500 lg:col-span-1">
                <div class="flex justify-between items-center mb-4">
                    <div class="flex items-center">
                        <div class="p-2 bg-yellow-100 dark:bg-yellow-900/30 text-yellow-600 rounded-lg mr-3">
                            <i class="fas fa-trophy"></i>
                        </div>
                        <h3 class="font-bold text-gray-800 dark:text-gray-200">Leaderboard</h3>
                    </div>
                </div>

                <div class="space-y-3">
                    <div class="flex items-center justify-between bg-yellow-50 dark:bg-yellow-900/10 p-2 rounded-lg border border-yellow-100 dark:border-yellow-900/30">
                        <div class="flex items-center gap-2">
                            <span class="font-bold text-yellow-500">#1</span>
                            <div class="w-8 h-8 rounded-full bg-blue-500 flex items-center justify-center text-white text-xs font-bold shadow">AM</div>
                            <div>
                                <p class="text-sm font-bold text-gray-800 dark:text-gray-200">Ana Machado</p>
                                <p class="text-[10px] text-gray-500">12 Churns evitados</p>
                            </div>
                        </div>
                        <span class="text-sm font-bold text-yellow-600 dark:text-yellow-500">1,250 pts</span>
                    </div>

                    <div class="flex items-center justify-between p-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                        <div class="flex items-center gap-2">
                            <span class="font-bold text-gray-400">#2</span>
                            <div class="w-8 h-8 rounded-full bg-green-500 flex items-center justify-center text-white text-xs font-bold">CR</div>
                            <div>
                                <p class="text-sm font-medium text-gray-700 dark:text-gray-300">Carlos Reis</p>
                                <p class="text-[10px] text-gray-500">8 Churns evitados</p>
                            </div>
                        </div>
                        <span class="text-sm font-medium text-gray-600 dark:text-gray-400">980 pts</span>
                    </div>

                    <div class="flex items-center justify-between p-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                        <div class="flex items-center gap-2">
                            <span class="font-bold text-gray-400">#3</span>
                            <div class="w-8 h-8 rounded-full bg-purple-500 flex items-center justify-center text-white text-xs font-bold">Você</div>
                            <div>
                                <p class="text-sm font-medium text-gray-700 dark:text-gray-300">Seu Perfil</p>
                                <p class="text-[10px] text-gray-500">3 Churns evitados</p>
                            </div>
                        </div>
                        <span class="text-sm font-medium text-gray-600 dark:text-gray-400">450 pts</span>
                    </div>
                </div>
            </div>

            <!-- CSAT & Sentimentos -->
            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border-t-4 border-green-500 lg:col-span-2">
                <div class="flex items-center mb-4">
                    <div class="p-2 bg-green-100 dark:bg-green-900/30 text-green-500 rounded-lg mr-3">
                        <i class="fas fa-smile-beam"></i>
                    </div>
                    <h3 class="font-bold text-gray-800 dark:text-gray-200">CSAT & Sentimentos</h3>
                </div>

                <div class="flex flex-col md:flex-row gap-6 items-center">
                    <div class="w-full md:w-1/3 text-center">
                        <div class="text-5xl font-black text-green-500 mb-2">4.8<span class="text-2xl text-gray-400">/5</span></div>
                        <div class="flex justify-center text-yellow-400 mb-1">
                            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
                        </div>
                        <p class="text-xs text-gray-500">CSAT Baseado em 342 avaliações</p>
                    </div>

                    <div class="w-full md:w-2/3 space-y-3">
                        <div>
                            <div class="flex justify-between text-xs mb-1">
                                <span><i class="far fa-laugh-beam text-green-500"></i> Positivo</span>
                                <span class="font-bold text-gray-700 dark:text-gray-300">75%</span>
                            </div>
                            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-1.5">
                                <div class="bg-green-500 h-1.5 rounded-full" style="width: 75%"></div>
                            </div>
                        </div>
                        <div>
                            <div class="flex justify-between text-xs mb-1">
                                <span><i class="far fa-meh text-gray-500"></i> Neutro</span>
                                <span class="font-bold text-gray-700 dark:text-gray-300">18%</span>
                            </div>
                            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-1.5">
                                <div class="bg-gray-400 h-1.5 rounded-full" style="width: 18%"></div>
                            </div>
                        </div>
                        <div>
                            <div class="flex justify-between text-xs mb-1">
                                <span><i class="far fa-frown text-red-500"></i> Negativo</span>
                                <span class="font-bold text-gray-700 dark:text-gray-300">7%</span>
                            </div>
                            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-1.5">
                                <div class="bg-red-500 h-1.5 rounded-full" style="width: 7%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Colaboração Mini-Chat -->
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border-t-4 border-blue-500 flex flex-col h-full lg:col-span-3">
                <div class="p-4 border-b border-gray-100 dark:border-gray-700 flex justify-between items-center">
                    <div class="flex items-center">
                        <div class="p-2 bg-blue-100 dark:bg-blue-900/30 text-blue-500 rounded-lg mr-3">
                            <i class="fas fa-comments"></i>
                        </div>
                        <h3 class="font-bold text-gray-800 dark:text-gray-200">Chat da Equipe</h3>
                    </div>
                    <span class="flex items-center gap-1 text-xs text-green-500"><div class="w-2 h-2 rounded-full bg-green-500"></div> 3 Online</span>
                </div>

                <div class="p-4 flex-1 bg-gray-50/50 dark:bg-gray-900/30 space-y-4 max-h-[300px] overflow-y-auto">
                    <div class="flex gap-3">
                        <div class="w-8 h-8 rounded-full bg-blue-500 flex-shrink-0 flex items-center justify-center text-white text-xs font-bold">M</div>
                        <div>
                            <div class="bg-white dark:bg-gray-700 p-3 rounded-lg rounded-tl-none shadow-sm border border-gray-100 dark:border-gray-600">
                                <p class="text-sm text-gray-800 dark:text-gray-200">Alguém consegue verificar a Empresa Beta? O risco de churn subiu para 89%.</p>
                            </div>
                            <span class="text-[10px] text-gray-500 ml-1 mt-1">Marcos • 14:32</span>
                        </div>
                    </div>
                    <div class="flex gap-3 flex-row-reverse">
                        <div class="w-8 h-8 rounded-full bg-green-500 flex-shrink-0 flex items-center justify-center text-white text-xs font-bold">A</div>
                        <div class="flex flex-col items-end">
                            <div class="bg-primary text-white p-3 rounded-lg rounded-tr-none shadow-sm">
                                <p class="text-sm">Deixa comigo, enviei um cupom de 20% para a próxima renovação e convidei para uma call.</p>
                            </div>
                            <span class="text-[10px] text-gray-500 mr-1 mt-1">Ana (Você) • 14:35</span>
                        </div>
                    </div>
                </div>
                <div class="p-3 border-t border-gray-100 dark:border-gray-700 bg-white dark:bg-gray-800">
                    <div class="relative">
                        <input type="text" placeholder="Digite uma mensagem..." class="w-full bg-gray-100 dark:bg-gray-700 border-none rounded-full py-2 pl-4 pr-10 text-sm focus:ring-2 focus:ring-primary focus:outline-none">
                        <button class="absolute right-2 top-1/2 transform -translate-y-1/2 text-primary hover:text-blue-600 w-8 h-8 flex items-center justify-center rounded-full hover:bg-blue-50 dark:hover:bg-gray-600 transition-colors">
                            <i class="fas fa-paper-plane text-xs"></i>
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

<%- include('partials/footer') %>
