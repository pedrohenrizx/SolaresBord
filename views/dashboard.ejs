<%- include('partials/header') %>

<div class="flex flex-col md:flex-row min-h-screen">
    <!-- Sidebar -->
    <aside class="w-full md:w-64 bg-white dark:bg-gray-800 shadow-md md:flex-shrink-0">
        <div class="p-4">
            <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Menu</h2>
            <ul class="space-y-2">
                <li>
                    <a href="/dashboard" class="block px-4 py-2 rounded-lg bg-primary/10 text-primary font-medium">
                        <i class="fas fa-home w-5"></i> Dashboard
                    </a>
                </li>
                <li>
                    <a href="/segmentation" class="block px-4 py-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                        <i class="fas fa-users w-5"></i> Segmentação
                    </a>
                </li>
                <% if (locals.userPlan !== 'pro') { %>
                <li>
                    <a href="/upgrade" class="block px-4 py-2 rounded-lg text-amber-600 dark:text-amber-400 hover:bg-amber-50 dark:hover:bg-amber-900/20 transition-colors font-medium">
                        <i class="fas fa-star w-5"></i> Upgrade para Pro
                    </a>
                </li>
                <% } else { %>
                <li>
                    <a href="/pro" class="block px-4 py-2 rounded-lg text-purple-600 dark:text-purple-400 hover:bg-purple-50 dark:hover:bg-purple-900/20 transition-colors font-medium">
                        <i class="fas fa-crown w-5"></i> Funcionalidades Pro
                    </a>
                </li>
                <% } %>
            </ul>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-4 md:p-8">
        <div class="mb-8 flex justify-between items-center">
            <h1 class="text-2xl font-bold">Visão Geral</h1>
            <% if (locals.userPlan === 'pro') { %>
                <span class="bg-gradient-to-r from-purple-500 to-indigo-500 text-white px-3 py-1 rounded-full text-xs font-bold uppercase shadow-sm">Pro Plan</span>
            <% } else { %>
                <span class="bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-3 py-1 rounded-full text-xs font-bold uppercase shadow-sm">Free Plan</span>
            <% } %>
        </div>

        <!-- KPIs -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
            <div class="bg-white dark:bg-gray-800 p-4 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Clientes Ativos</p>
                        <h3 class="text-2xl font-bold mt-1">1,248</h3>
                    </div>
                    <div class="p-2 bg-blue-50 dark:bg-blue-900/20 rounded-lg text-blue-500">
                        <i class="fas fa-users"></i>
                    </div>
                </div>
                <p class="text-xs text-green-500 mt-2"><i class="fas fa-arrow-up"></i> 12% desde o último mês</p>
            </div>

            <div class="bg-white dark:bg-gray-800 p-4 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Taxa de Conversão</p>
                        <h3 class="text-2xl font-bold mt-1">3.4%</h3>
                    </div>
                    <div class="p-2 bg-green-50 dark:bg-green-900/20 rounded-lg text-green-500">
                        <i class="fas fa-chart-line"></i>
                    </div>
                </div>
                <p class="text-xs text-green-500 mt-2"><i class="fas fa-arrow-up"></i> 0.8% desde o último mês</p>
            </div>

            <div class="bg-white dark:bg-gray-800 p-4 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Receita Média</p>
                        <h3 class="text-2xl font-bold mt-1">R$ 450</h3>
                    </div>
                    <div class="p-2 bg-purple-50 dark:bg-purple-900/20 rounded-lg text-purple-500">
                        <i class="fas fa-wallet"></i>
                    </div>
                </div>
                <p class="text-xs text-red-500 mt-2"><i class="fas fa-arrow-down"></i> 2% desde o último mês</p>
            </div>

            <div class="bg-white dark:bg-gray-800 p-4 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Índice de Retenção</p>
                        <h3 class="text-2xl font-bold mt-1">85%</h3>
                    </div>
                    <div class="p-2 bg-amber-50 dark:bg-amber-900/20 rounded-lg text-amber-500">
                        <i class="fas fa-heart"></i>
                    </div>
                </div>
                <p class="text-xs text-green-500 mt-2"><i class="fas fa-arrow-up"></i> 5% desde o último mês</p>
            </div>
        </div>

        <!-- Charts -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="bg-white dark:bg-gray-800 p-4 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-4">Crescimento de Clientes</h3>
                <canvas id="growthChart" height="200"></canvas>
            </div>
            <div class="bg-white dark:bg-gray-800 p-4 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-4">Aquisição por Canal</h3>
                <canvas id="channelChart" height="200"></canvas>
            </div>
        </div>
    </main>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const isDarkMode = document.documentElement.classList.contains('dark');
        const textColor = isDarkMode ? '#9ca3af' : '#4b5563';
        const gridColor = isDarkMode ? '#374151' : '#e5e7eb';

        // Growth Chart
        const ctxGrowth = document.getElementById('growthChart').getContext('2d');
        new Chart(ctxGrowth, {
            type: 'line',
            data: {
                labels: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun'],
                datasets: [{
                    label: 'Novos Clientes',
                    data: [65, 78, 90, 105, 125, 150],
                    borderColor: '#3b82f6',
                    backgroundColor: 'rgba(59, 130, 246, 0.1)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    x: { ticks: { color: textColor }, grid: { color: gridColor } },
                    y: { ticks: { color: textColor }, grid: { color: gridColor } }
                }
            }
        });

        // Channel Chart
        const ctxChannel = document.getElementById('channelChart').getContext('2d');
        new Chart(ctxChannel, {
            type: 'doughnut',
            data: {
                labels: ['Site', 'Redes Sociais', 'Loja Física', 'Indicação'],
                datasets: [{
                    data: [45, 30, 15, 10],
                    backgroundColor: ['#3b82f6', '#10b981', '#f59e0b', '#8b5cf6'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom', labels: { color: textColor } }
                }
            }
        });
    });
</script>

<%- include('partials/footer') %>
