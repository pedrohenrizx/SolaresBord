<%- include('partials/header') %>

<div class="flex flex-col md:flex-row min-h-screen">
    <!-- Sidebar -->
    <aside class="w-full md:w-64 bg-white dark:bg-gray-800 shadow-md md:flex-shrink-0">
        <div class="p-4">
            <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Menu</h2>
            <ul class="space-y-2">
                <li>
                    <a href="/dashboard" class="block px-4 py-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                        <i class="fas fa-home w-5"></i> Dashboard
                    </a>
                </li>
                <li>
                    <a href="/segmentation" class="block px-4 py-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                        <i class="fas fa-users w-5"></i> Segmentação
                    </a>
                </li>
                <li>
                    <a href="/pro" class="block px-4 py-2 rounded-lg bg-purple-50 text-purple-600 dark:bg-purple-900/20 dark:text-purple-400 font-medium">
                        <i class="fas fa-crown w-5"></i> Funcionalidades Pro
                    </a>
                </li>
            </ul>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-4 md:p-8">
        <div class="mb-8 flex justify-between items-center border-b border-gray-200 dark:border-gray-700 pb-4">
            <div>
                <h1 class="text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-purple-500 to-indigo-500">Área Exclusiva Pro</h1>
                <p class="text-gray-600 dark:text-gray-400">Ferramentas avançadas liberadas para sua conta.</p>
            </div>
            <div class="text-3xl text-purple-500">
                <i class="fas fa-gem"></i>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Predição de Churn -->
            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-md border-t-4 border-red-500">
                <div class="flex items-center mb-4">
                    <div class="p-3 bg-red-100 dark:bg-red-900/30 text-red-500 rounded-lg mr-4">
                        <i class="fas fa-exclamation-triangle text-xl"></i>
                    </div>
                    <h3 class="text-lg font-bold">Risco de Churn (Previsão)</h3>
                </div>
                <p class="text-gray-600 dark:text-gray-400 mb-4 text-sm">O sistema identificou 3 clientes com alto risco de cancelamento baseados no comportamento recente.</p>
                <div class="space-y-3">
                    <div class="flex justify-between items-center bg-gray-50 dark:bg-gray-700/50 p-2 rounded">
                        <span class="font-medium text-sm">Empresa Beta</span>
                        <span class="text-xs bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300 px-2 py-1 rounded">Risco: 89%</span>
                    </div>
                    <div class="flex justify-between items-center bg-gray-50 dark:bg-gray-700/50 p-2 rounded">
                        <span class="font-medium text-sm">Carlos Almeida</span>
                        <span class="text-xs bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300 px-2 py-1 rounded">Risco: 75%</span>
                    </div>
                </div>
                <button class="mt-4 w-full text-center text-sm text-primary hover:underline">Ver relatório completo</button>
            </div>

            <!-- NPS -->
            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-md border-t-4 border-green-500">
                <div class="flex items-center mb-4">
                    <div class="p-3 bg-green-100 dark:bg-green-900/30 text-green-500 rounded-lg mr-4">
                        <i class="fas fa-smile text-xl"></i>
                    </div>
                    <h3 class="text-lg font-bold">Monitoramento de NPS</h3>
                </div>
                <div class="flex items-end mb-2">
                    <span class="text-4xl font-extrabold text-gray-800 dark:text-white">72</span>
                    <span class="text-gray-500 ml-2 mb-1">Score Excelente</span>
                </div>
                <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2.5 mb-4">
                    <div class="bg-green-500 h-2.5 rounded-full" style="width: 72%"></div>
                </div>
                <p class="text-xs text-gray-500 dark:text-gray-400">Baseado em 154 respostas nas últimas 2 semanas.</p>
                <div class="mt-4 p-3 bg-gray-50 dark:bg-gray-700/50 rounded-lg text-sm italic border-l-2 border-green-500">
                    "O suporte foi incrivelmente rápido e resolveu meu problema na hora!" - Cliente Promotor
                </div>
            </div>

            <!-- Colaboração -->
            <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-md md:col-span-2 border-t-4 border-blue-500">
                <div class="flex justify-between items-center mb-4">
                    <div class="flex items-center">
                        <div class="p-3 bg-blue-100 dark:bg-blue-900/30 text-blue-500 rounded-lg mr-4">
                            <i class="fas fa-comments text-xl"></i>
                        </div>
                        <h3 class="text-lg font-bold">Notas da Equipe & Gamificação</h3>
                    </div>
                    <button class="text-sm bg-primary text-white px-3 py-1 rounded hover:bg-blue-600">+ Nova Nota</button>
                </div>

                <div class="flex gap-4 mb-6 overflow-x-auto pb-2">
                    <!-- Gamification badges -->
                    <div class="flex flex-col items-center bg-gray-50 dark:bg-gray-700/50 p-3 rounded-lg min-w-[100px]">
                        <i class="fas fa-medal text-yellow-500 text-2xl mb-1"></i>
                        <span class="text-xs font-bold">Top Saver</span>
                        <span class="text-[10px] text-gray-500">Ana resgatou 5 churns</span>
                    </div>
                    <div class="flex flex-col items-center bg-gray-50 dark:bg-gray-700/50 p-3 rounded-lg min-w-[100px]">
                        <i class="fas fa-rocket text-purple-500 text-2xl mb-1"></i>
                        <span class="text-xs font-bold">NPS Master</span>
                        <span class="text-[10px] text-gray-500">Equipe de Vendas</span>
                    </div>
                </div>

                <div class="space-y-4">
                    <div class="flex gap-3">
                        <div class="w-8 h-8 rounded-full bg-blue-500 flex items-center justify-center text-white font-bold text-xs">M</div>
                        <div class="flex-1 bg-gray-50 dark:bg-gray-700/50 p-3 rounded-lg rounded-tl-none">
                            <p class="text-sm text-gray-800 dark:text-gray-200">Alguém consegue verificar a Empresa Beta? O risco de churn subiu para 89%.</p>
                            <span class="text-[10px] text-gray-500">Marcos • 2h atrás</span>
                        </div>
                    </div>
                    <div class="flex gap-3">
                        <div class="w-8 h-8 rounded-full bg-green-500 flex items-center justify-center text-white font-bold text-xs">A</div>
                        <div class="flex-1 bg-gray-50 dark:bg-gray-700/50 p-3 rounded-lg rounded-tl-none">
                            <p class="text-sm text-gray-800 dark:text-gray-200">Deixa comigo, enviei um cupom de 20% para a próxima renovação e convidei para uma call.</p>
                            <span class="text-[10px] text-gray-500">Ana • 1h atrás</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<%- include('partials/footer') %>
