<%- include('partials/header') %>

<div class="flex flex-col md:flex-row min-h-screen">
    <!-- Sidebar -->
    <aside class="w-full md:w-64 bg-white dark:bg-gray-800 shadow-md md:flex-shrink-0">
        <div class="p-4">
            <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Menu</h2>
            <ul class="space-y-2">
                <li>
                    <a href="/dashboard" class="block px-4 py-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                        <i class="fas fa-home w-5"></i> Dashboard
                    </a>
                </li>
                <li>
                    <a href="/segmentation" class="block px-4 py-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                        <i class="fas fa-users w-5"></i> Segmentação
                    </a>
                </li>
                <li>
                    <a href="/upgrade" class="block px-4 py-2 rounded-lg bg-amber-50 text-amber-600 dark:bg-amber-900/20 dark:text-amber-400 font-medium">
                        <i class="fas fa-star w-5"></i> Upgrade para Pro
                    </a>
                </li>
            </ul>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-4 md:p-8 flex items-center justify-center">
        <div class="max-w-md w-full bg-white dark:bg-gray-800 p-8 rounded-2xl shadow-xl text-center border-t-4 border-amber-500">
            <div class="w-16 h-16 bg-amber-100 dark:bg-amber-900/30 text-amber-500 rounded-full flex items-center justify-center mx-auto mb-6 text-3xl">
                <i class="fas fa-crown"></i>
            </div>
            <h1 class="text-2xl font-bold mb-2">Desbloqueie o Plano Pro</h1>
            <p class="text-gray-600 dark:text-gray-400 mb-6">Tenha acesso a previsões inteligentes, relatórios exportáveis, NPS e colaboração em equipe.</p>

            <ul class="text-left mb-8 space-y-3">
                <li class="flex items-center text-sm"><i class="fas fa-check text-green-500 mr-2"></i> Exportação de relatórios em CSV/PDF</li>
                <li class="flex items-center text-sm"><i class="fas fa-check text-green-500 mr-2"></i> Monitoramento de NPS e Sentimentos</li>
                <li class="flex items-center text-sm"><i class="fas fa-check text-green-500 mr-2"></i> Alertas preditivos de churn</li>
                <li class="flex items-center text-sm"><i class="fas fa-check text-green-500 mr-2"></i> Colaboração em tempo real</li>
            </ul>

            <button id="confirmPaymentBtn" class="w-full bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-600 hover:to-orange-600 text-white font-bold py-3 px-4 rounded-xl shadow-lg transition-all transform hover:scale-[1.02]">
                Simular Pagamento & Fazer Upgrade
            </button>
            <p class="text-xs text-gray-500 mt-4">*Isto é apenas uma simulação.</p>
        </div>
    </main>
</div>

<script>
    document.getElementById('confirmPaymentBtn').addEventListener('click', async () => {
        const btn = document.getElementById('confirmPaymentBtn');
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processando...';
        btn.disabled = true;

        try {
            const res = await fetch('/api/upgrade', { method: 'POST' });
            if (res.ok) {
                alert('Pagamento Confirmado! Bem-vindo ao plano Pro.');
                window.location.href = '/pro';
            } else {
                alert('Erro ao processar upgrade.');
                btn.innerHTML = 'Simular Pagamento & Fazer Upgrade';
                btn.disabled = false;
            }
        } catch (e) {
            console.error(e);
            alert('Erro de conexão.');
            btn.innerHTML = 'Simular Pagamento & Fazer Upgrade';
            btn.disabled = false;
        }
    });
</script>

<%- include('partials/footer') %>
