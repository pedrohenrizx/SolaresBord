<%- include('partials/header') %>

    <!-- Sidebar -->
    <aside id="sidebar" class="absolute md:static z-30 transform -translate-x-full md:translate-x-0 transition-transform duration-300 w-64 bg-white dark:bg-gray-800 shadow-lg md:shadow-md md:flex-shrink-0 min-h-[calc(100vh-4rem)] flex flex-col justify-between">
        <div class="p-4">
            <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Menu</h2>
            <ul class="space-y-2">
                <li>
                    <a href="/dashboard" class="block px-4 py-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                        <i class="fas fa-home w-5"></i> Dashboard
                    </a>
                </li>
                <li>
                    <a href="/segmentation" class="block px-4 py-2 rounded-lg bg-primary/10 text-primary font-medium">
                        <i class="fas fa-users w-5"></i> Segmentação
                    </a>
                </li>
                <li>
                    <a href="/advanced" class="block px-4 py-2 rounded-lg text-purple-600 dark:text-purple-400 hover:bg-purple-50 dark:hover:bg-purple-900/20 transition-colors font-medium group">
                        <i class="fas fa-cogs w-5 group-hover:rotate-90 transition-transform"></i> Funcionalidades Avançadas
                    </a>
                </li>
            </ul>
        </div>

        <!-- Sidebar Collapse Hint -->
        <div class="p-4 border-t border-gray-100 dark:border-gray-700 hidden md:block text-center text-xs text-gray-400 cursor-pointer hover:text-gray-600 transition-colors">
            <i class="fas fa-angle-double-left mr-1"></i> Ocultar Menu
        </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 p-4 md:p-8 w-full overflow-x-hidden">
        <div class="mb-8">
            <h1 class="text-2xl font-bold">Segmentação de Clientes</h1>
            <p class="text-gray-600 dark:text-gray-400">Classifique e gerencie diferentes grupos de clientes.</p>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
            <div class="p-4 border-b border-gray-100 dark:border-gray-700 flex flex-col md:flex-row justify-between items-center gap-4">
                <h3 class="font-semibold">Filtros Avançados</h3>
                <div class="flex gap-2 w-full md:w-auto">
                    <div class="relative flex-1 md:w-64">
                        <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 text-sm"></i>
                        <input type="text" placeholder="Buscar por nome ou email..." class="w-full pl-9 pr-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-sm focus:outline-none focus:ring-2 focus:ring-primary dark:text-white">
                    </div>
                    <button class="bg-primary text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-600 transition-colors shadow-sm whitespace-nowrap">
                        <i class="fas fa-filter"></i> <span class="hidden sm:inline">Aplicar Filtros</span>
                    </button>
                </div>
            </div>
            <div class="p-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 bg-gray-50/50 dark:bg-gray-800/50">
                <div>
                    <label class="block text-xs font-medium mb-1 text-gray-500 dark:text-gray-400">Status</label>
                    <select class="w-full border border-gray-300 dark:border-gray-600 dark:bg-gray-700 rounded-lg shadow-sm focus:ring-primary focus:border-primary p-2 text-sm">
                        <option>Todos</option>
                        <option>Ativos</option>
                        <option>Inativos</option>
                        <option>Em Risco</option>
                        <option>Novos</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-medium mb-1 text-gray-500 dark:text-gray-400">Localização</label>
                    <select class="w-full border border-gray-300 dark:border-gray-600 dark:bg-gray-700 rounded-lg shadow-sm focus:ring-primary focus:border-primary p-2 text-sm">
                        <option>Brasil</option>
                        <option>São Paulo</option>
                        <option>Rio de Janeiro</option>
                        <option>Exterior</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-medium mb-1 text-gray-500 dark:text-gray-400">Valor Gasto</label>
                    <select class="w-full border border-gray-300 dark:border-gray-600 dark:bg-gray-700 rounded-lg shadow-sm focus:ring-primary focus:border-primary p-2 text-sm">
                        <option>Qualquer</option>
                        <option>> R$ 1000</option>
                        <option>R$ 500 - R$ 1000</option>
                        <option>< R$ 500</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-medium mb-1 text-gray-500 dark:text-gray-400">Origem</label>
                    <select class="w-full border border-gray-300 dark:border-gray-600 dark:bg-gray-700 rounded-lg shadow-sm focus:ring-primary focus:border-primary p-2 text-sm">
                        <option>Todas</option>
                        <option>Orgânico</option>
                        <option>Anúncios</option>
                        <option>Indicação</option>
                    </select>
                </div>
            </div>

            <div class="overflow-x-auto min-h-[300px]">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-50 dark:bg-gray-700/80 border-y border-gray-200 dark:border-gray-600">
                            <th class="p-3 text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wider w-10">
                                <input type="checkbox" class="rounded border-gray-300 text-primary focus:ring-primary">
                            </th>
                            <th class="p-3 text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wider cursor-pointer hover:text-gray-900 dark:hover:text-white">Cliente <i class="fas fa-sort ml-1"></i></th>
                            <th class="p-3 text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wider cursor-pointer hover:text-gray-900 dark:hover:text-white">Status <i class="fas fa-sort ml-1"></i></th>
                            <th class="p-3 text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wider cursor-pointer hover:text-gray-900 dark:hover:text-white">Última Compra <i class="fas fa-sort ml-1"></i></th>
                            <th class="p-3 text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wider cursor-pointer hover:text-gray-900 dark:hover:text-white">Total Gasto <i class="fas fa-sort ml-1"></i></th>
                            <th class="p-3 text-xs font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wider text-right">Ações</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors group">
                            <td class="p-3"><input type="checkbox" class="rounded border-gray-300 text-primary focus:ring-primary"></td>
                            <td class="p-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-xs">JS</div>
                                    <div>
                                        <div class="font-medium text-sm">João Silva</div>
                                        <div class="text-xs text-gray-500">joao@email.com</div>
                                    </div>
                                </div>
                            </td>
                            <td class="p-3"><span class="px-2 py-1 text-[10px] font-semibold bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400 rounded-full border border-green-200 dark:border-green-800">Ativo</span></td>
                            <td class="p-3 text-sm text-gray-600 dark:text-gray-300">2 dias atrás</td>
                            <td class="p-3 text-sm font-medium">R$ 1.250,00</td>
                            <td class="p-3 text-right">
                                <button class="text-gray-400 hover:text-primary transition-colors p-1"><i class="fas fa-ellipsis-v"></i></button>
                            </td>
                        </tr>
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors group">
                            <td class="p-3"><input type="checkbox" class="rounded border-gray-300 text-primary focus:ring-primary"></td>
                            <td class="p-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-purple-100 text-purple-600 flex items-center justify-center font-bold text-xs">MS</div>
                                    <div>
                                        <div class="font-medium text-sm">Maria Santos</div>
                                        <div class="text-xs text-gray-500">maria@email.com</div>
                                    </div>
                                </div>
                            </td>
                            <td class="p-3"><span class="px-2 py-1 text-[10px] font-semibold bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400 rounded-full border border-red-200 dark:border-red-800">Inativo</span></td>
                            <td class="p-3 text-sm text-gray-600 dark:text-gray-300">3 meses atrás</td>
                            <td class="p-3 text-sm font-medium">R$ 450,00</td>
                            <td class="p-3 text-right">
                                <button class="text-gray-400 hover:text-primary transition-colors p-1"><i class="fas fa-ellipsis-v"></i></button>
                            </td>
                        </tr>
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors group">
                            <td class="p-3"><input type="checkbox" class="rounded border-gray-300 text-primary focus:ring-primary"></td>
                            <td class="p-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-amber-100 text-amber-600 flex items-center justify-center font-bold text-xs">EA</div>
                                    <div>
                                        <div class="font-medium text-sm">Empresa ABC</div>
                                        <div class="text-xs text-gray-500">contato@abc.com</div>
                                    </div>
                                </div>
                            </td>
                            <td class="p-3"><span class="px-2 py-1 text-[10px] font-semibold bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400 rounded-full border border-amber-200 dark:border-amber-800">Em Risco</span></td>
                            <td class="p-3 text-sm text-gray-600 dark:text-gray-300">1 mês atrás</td>
                            <td class="p-3 text-sm font-medium">R$ 3.800,00</td>
                            <td class="p-3 text-right">
                                <button class="text-gray-400 hover:text-primary transition-colors p-1"><i class="fas fa-ellipsis-v"></i></button>
                            </td>
                        </tr>
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors group">
                            <td class="p-3"><input type="checkbox" class="rounded border-gray-300 text-primary focus:ring-primary"></td>
                            <td class="p-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-xs">LC</div>
                                    <div>
                                        <div class="font-medium text-sm">Lucas Costa</div>
                                        <div class="text-xs text-gray-500">lucas@email.com</div>
                                    </div>
                                </div>
                            </td>
                            <td class="p-3"><span class="px-2 py-1 text-[10px] font-semibold bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400 rounded-full border border-blue-200 dark:border-blue-800">Novo</span></td>
                            <td class="p-3 text-sm text-gray-600 dark:text-gray-300">Hoje</td>
                            <td class="p-3 text-sm font-medium">R$ 150,00</td>
                            <td class="p-3 text-right">
                                <button class="text-gray-400 hover:text-primary transition-colors p-1"><i class="fas fa-ellipsis-v"></i></button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="p-4 border-t border-gray-100 dark:border-gray-700 flex flex-col sm:flex-row justify-between items-center gap-4 bg-gray-50/30 dark:bg-gray-800/30">
                <span class="text-sm text-gray-500">Mostrando 1 a 4 de 1,248 clientes</span>

                <!-- Pagination -->
                <nav class="inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                    <a href="#" class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-medium text-gray-500 hover:bg-gray-50 dark:hover:bg-gray-700">
                        <span class="sr-only">Anterior</span>
                        <i class="fas fa-chevron-left"></i>
                    </a>
                    <a href="#" class="relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 bg-blue-50 dark:bg-gray-700 text-sm font-medium text-primary">1</a>
                    <a href="#" class="relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-medium text-gray-500 hover:bg-gray-50 dark:hover:bg-gray-700">2</a>
                    <a href="#" class="relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-medium text-gray-500 hover:bg-gray-50 dark:hover:bg-gray-700">3</a>
                    <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-medium text-gray-700">...</span>
                    <a href="#" class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-medium text-gray-500 hover:bg-gray-50 dark:hover:bg-gray-700">
                        <span class="sr-only">Próximo</span>
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </nav>

                <button class="bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 text-gray-800 dark:text-gray-200 px-4 py-2 rounded-lg text-sm hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors shadow-sm" onclick="showToast('Download do CSV iniciado', 'success')">
                    <i class="fas fa-download mr-1"></i> Exportar CSV
                </button>
            </div>
        </div>
    </div>

<%- include('partials/footer') %>
