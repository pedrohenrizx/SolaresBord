<%- include('partials/header') %>

<div class="flex flex-col md:flex-row min-h-screen">
    <!-- Sidebar -->
    <aside class="w-full md:w-64 bg-white dark:bg-gray-800 shadow-md md:flex-shrink-0">
        <div class="p-4">
            <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Menu</h2>
            <ul class="space-y-2">
                <li>
                    <a href="/dashboard" class="block px-4 py-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                        <i class="fas fa-home w-5"></i> Dashboard
                    </a>
                </li>
                <li>
                    <a href="/segmentation" class="block px-4 py-2 rounded-lg bg-primary/10 text-primary font-medium">
                        <i class="fas fa-users w-5"></i> Segmentação
                    </a>
                </li>
                <% if (locals.userPlan !== 'pro') { %>
                <li>
                    <a href="/upgrade" class="block px-4 py-2 rounded-lg text-amber-600 dark:text-amber-400 hover:bg-amber-50 dark:hover:bg-amber-900/20 transition-colors font-medium">
                        <i class="fas fa-star w-5"></i> Upgrade para Pro
                    </a>
                </li>
                <% } else { %>
                <li>
                    <a href="/pro" class="block px-4 py-2 rounded-lg text-purple-600 dark:text-purple-400 hover:bg-purple-50 dark:hover:bg-purple-900/20 transition-colors font-medium">
                        <i class="fas fa-crown w-5"></i> Funcionalidades Pro
                    </a>
                </li>
                <% } %>
            </ul>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-4 md:p-8">
        <div class="mb-8">
            <h1 class="text-2xl font-bold">Segmentação de Clientes</h1>
            <p class="text-gray-600 dark:text-gray-400">Classifique e gerencie diferentes grupos de clientes.</p>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
            <div class="p-4 border-b border-gray-100 dark:border-gray-700 flex justify-between items-center">
                <h3 class="font-semibold">Filtros Avançados</h3>
                <button class="bg-primary text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-600 transition-colors">
                    <i class="fas fa-filter"></i> Aplicar Filtros
                </button>
            </div>
            <div class="p-4 grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">Status</label>
                    <select class="w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 rounded-lg shadow-sm focus:ring-primary focus:border-primary p-2">
                        <option>Todos</option>
                        <option>Ativos</option>
                        <option>Inativos</option>
                        <option>Em Risco</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">Localização</label>
                    <select class="w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 rounded-lg shadow-sm focus:ring-primary focus:border-primary p-2">
                        <option>Brasil</option>
                        <option>América Latina</option>
                        <option>Global</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">Valor Gasto</label>
                    <select class="w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 rounded-lg shadow-sm focus:ring-primary focus:border-primary p-2">
                        <option>> R$ 1000</option>
                        <option>R$ 500 - R$ 1000</option>
                        <option>< R$ 500</option>
                    </select>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-50 dark:bg-gray-700/50">
                            <th class="p-4 text-sm font-semibold text-gray-600 dark:text-gray-300">Cliente</th>
                            <th class="p-4 text-sm font-semibold text-gray-600 dark:text-gray-300">Status</th>
                            <th class="p-4 text-sm font-semibold text-gray-600 dark:text-gray-300">Última Compra</th>
                            <th class="p-4 text-sm font-semibold text-gray-600 dark:text-gray-300">Total Gasto</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                            <td class="p-4">
                                <div class="font-medium">João Silva</div>
                                <div class="text-sm text-gray-500">joao@email.com</div>
                            </td>
                            <td class="p-4"><span class="px-2 py-1 text-xs font-semibold bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400 rounded-full">Ativo</span></td>
                            <td class="p-4 text-sm">2 dias atrás</td>
                            <td class="p-4 text-sm">R$ 1.250,00</td>
                        </tr>
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                            <td class="p-4">
                                <div class="font-medium">Maria Santos</div>
                                <div class="text-sm text-gray-500">maria@email.com</div>
                            </td>
                            <td class="p-4"><span class="px-2 py-1 text-xs font-semibold bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400 rounded-full">Inativo</span></td>
                            <td class="p-4 text-sm">3 meses atrás</td>
                            <td class="p-4 text-sm">R$ 450,00</td>
                        </tr>
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                            <td class="p-4">
                                <div class="font-medium">Empresa ABC</div>
                                <div class="text-sm text-gray-500">contato@abc.com</div>
                            </td>
                            <td class="p-4"><span class="px-2 py-1 text-xs font-semibold bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400 rounded-full">Em Risco</span></td>
                            <td class="p-4 text-sm">1 mês atrás</td>
                            <td class="p-4 text-sm">R$ 3.800,00</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <% if (locals.userPlan !== 'pro') { %>
            <div class="p-6 bg-gray-50 dark:bg-gray-800 text-center border-t border-gray-200 dark:border-gray-700">
                <p class="text-gray-600 dark:text-gray-400 mb-4"><i class="fas fa-lock mr-2"></i> Exporte relatórios detalhados com o plano Pro.</p>
                <a href="/upgrade" class="inline-block bg-primary text-white font-medium px-6 py-2 rounded-lg hover:bg-blue-600 transition-colors">Fazer Upgrade</a>
            </div>
            <% } else { %>
            <div class="p-4 border-t border-gray-100 dark:border-gray-700 text-right">
                <button class="bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-gray-200 px-4 py-2 rounded-lg text-sm hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors">
                    <i class="fas fa-download"></i> Exportar CSV
                </button>
            </div>
            <% } %>
        </div>
    </main>
</div>

<%- include('partials/footer') %>
