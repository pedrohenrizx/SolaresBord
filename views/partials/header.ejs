<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CustomerFlow Analytics</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: '#3b82f6',
                        darkBg: '#111827',
                        lightBg: '#f3f4f6',
                    }
                }
            }
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-lightBg dark:bg-darkBg text-gray-900 dark:text-gray-100 min-h-screen flex flex-col transition-colors duration-200">
    <!-- Navbar -->
    <!-- Toast Notifications Container -->
    <div id="toastContainer" class="fixed top-4 right-4 z-50 flex flex-col gap-2"></div>

    <nav class="bg-white dark:bg-gray-800 shadow-md relative z-40">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center gap-4">
                    <% if (locals.userId) { %>
                    <button id="mobileMenuBtn" class="md:hidden text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">
                        <i class="fas fa-bars text-xl"></i>
                    </button>
                    <% } %>
                    <a href="/" class="flex-shrink-0 flex items-center gap-2">
                        <i class="fas fa-chart-line text-primary text-2xl"></i>
                        <span class="font-bold text-xl tracking-tight hidden sm:block">CustomerFlow</span>
                    </a>

                    <% if (locals.userId) { %>
                    <!-- Global Search -->
                    <div class="hidden sm:flex ml-6 relative">
                        <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                        <input type="text" placeholder="Buscar clientes, relatórios... (Ctrl+K)" class="pl-10 pr-4 py-1.5 w-64 rounded-full border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-sm focus:outline-none focus:ring-2 focus:ring-primary dark:text-white transition-all">
                    </div>
                    <% } %>
                </div>

                <div class="flex items-center gap-4">
                    <% if (locals.userId) { %>
                    <!-- Quick Add FAB in Navbar -->
                    <button class="hidden sm:flex bg-primary text-white p-2 rounded-full hover:bg-blue-600 transition-colors shadow-sm" title="Adição Rápida">
                        <i class="fas fa-plus"></i>
                    </button>
                    <!-- Notifications -->
                    <div class="relative cursor-pointer text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors" title="Notificações">
                        <i class="fas fa-bell text-lg"></i>
                        <span class="absolute -top-1 -right-1 bg-red-500 text-white text-[10px] font-bold w-4 h-4 flex items-center justify-center rounded-full border-2 border-white dark:border-gray-800">3</span>
                    </div>
                    <% } %>

                    <!-- Theme Toggle -->
                    <button id="themeToggle" class="p-2 rounded-md text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white focus:outline-none transition-colors">
                        <i class="fas fa-moon dark:hidden text-lg"></i>
                        <i class="fas fa-sun hidden dark:block text-lg"></i>
                    </button>

                    <% if (locals.userId) { %>
                    <!-- User Profile Dropdown -->
                    <div class="relative group cursor-pointer ml-2 flex items-center gap-2">
                        <div class="w-8 h-8 rounded-full bg-gradient-to-r from-blue-500 to-primary flex items-center justify-center text-white font-bold shadow-md">
                            U
                        </div>
                        <i class="fas fa-chevron-down text-xs text-gray-500 hidden sm:block group-hover:text-gray-900 dark:group-hover:text-white transition-colors"></i>

                        <!-- Dropdown Menu -->
                        <div class="absolute right-0 top-full mt-2 w-48 bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-right">
                            <div class="p-3 border-b border-gray-100 dark:border-gray-700">
                                <p class="text-sm font-medium">Usuário Teste</p>
                                <p class="text-xs text-gray-500 truncate">usuario@teste.com</p>
                            </div>
                            <div class="p-2">
                                <button id="logoutBtn" class="w-full text-left px-3 py-2 text-sm text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors flex items-center gap-2">
                                    <i class="fas fa-sign-out-alt"></i> Sair da conta
                                </button>
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>
    <main class="flex-grow flex flex-col md:flex-row relative">
